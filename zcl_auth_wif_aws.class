METHOD get_ext_idp_token.
    DATA: lv_imds_token    TYPE string,
          lv_role          TYPE string,
          ls_aws_creds     TYPE ty_aws_creds, 
          lo_http          TYPE REF TO if_http_client,
          lv_ts            TYPE timestamp,
          lv_date          TYPE d,
          lv_time          TYPE t,
          lv_tstr          TYPE string,
          lv_xdata         TYPE xstring,
          lv_bin           TYPE xstring,
          lv_fed_token     TYPE string,
          lv_sa_email      TYPE string.

    " --- CONFIGURATION (Adjust as needed) ---
    " In a real class, you'd likely fetch this from a member variable or config table
    lv_sa_email = 'svc-cloud-dla-sc-sbx-slt@dgee-dev-j65-data-fabric-0.iam.gserviceaccount.com'.

    " --- 1. FETCH DYNAMIC AWS CREDENTIALS ---
    cl_http_client=>create_by_url( EXPORTING url = 'http://169.254.169.254/latest/api/token' IMPORTING client = lo_http ).
    lo_http->request->set_method( 'PUT' ).
    lo_http->request->set_header_field( name = 'x-aws-ec2-metadata-token-ttl-seconds' value = '21600' ).
    lo_http->send( ). lo_http->receive( ).
    lv_imds_token = lo_http->response->get_cdata( ). lo_http->close( ).

    cl_http_client=>create_by_url( EXPORTING url = 'http://169.254.169.254/latest/meta-data/iam/security-credentials/' IMPORTING client = lo_http ).
    lo_http->request->set_header_field( name = 'x-aws-ec2-metadata-token' value = lv_imds_token ).
    lo_http->send( ). lo_http->receive( ).
    lv_role = lo_http->response->get_cdata( ). lo_http->close( ).

    cl_http_client=>create_by_url( EXPORTING url = |http://169.254.169.254/latest/meta-data/iam/security-credentials/{ lv_role }| IMPORTING client = lo_http ).
    lo_http->request->set_header_field( name = 'x-aws-ec2-metadata-token' value = lv_imds_token ).
    lo_http->send( ). lo_http->receive( ).
    /ui2/cl_json=>deserialize( EXPORTING json = lo_http->response->get_cdata( ) CHANGING data = ls_aws_creds ).
    lo_http->close( ).

    " --- 2. GENERATE AWS STS SUBJECT TOKEN (SigV4) ---
    GET TIME STAMP FIELD lv_ts.
    CONVERT TIME STAMP lv_ts TIME ZONE 'UTC' INTO DATE lv_date TIME lv_time.
    lv_tstr = |{ lv_date DATE = RAW }T{ lv_time TIME = RAW }Z|.
    
    CONDENSE ls_aws_creds-accesskeyid.
    CONDENSE ls_aws_creds-secretaccesskey.
    CONDENSE ls_aws_creds-token.

    DATA(lv_lf) = cl_abap_char_utilities=>newline.
    DATA(lv_empty_hash) = 'e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855'.
    DATA(lv_scope) = |{ lv_date DATE = RAW }/us-gov-west-1/sts/aws4_request|.
    
    DATA(lv_can_headers) = |host:sts.us-gov-west-1.amazonaws.com{ lv_lf }| &&
                           |x-amz-date:{ lv_tstr }{ lv_lf }| &&
                           |x-amz-security-token:{ ls_aws_creds-token }{ lv_lf }| &&
                           |x-goog-cloud-target-resource:{ iv_audience }{ lv_lf }|.
    
    DATA(lv_signed_hdrs) = 'host;x-amz-date;x-amz-security-token;x-goog-cloud-target-resource'.
    DATA(lv_can_req) = |POST{ lv_lf }/{ lv_lf }Action=GetCallerIdentity&Version=2011-06-15{ lv_lf }{ lv_can_headers }{ lv_lf }{ lv_signed_hdrs }{ lv_lf }{ lv_empty_hash }|.

    lv_xdata = cl_abap_conv_out_ce=>create( encoding = 'UTF-8' )->convert( data = lv_can_req ).
    cl_abap_message_digest=>calculate_hash_for_raw( EXPORTING if_algorithm = 'SHA256' if_data = lv_xdata IMPORTING ef_hashxstring = lv_bin ).
    DATA(lv_sts_str) = |AWS4-HMAC-SHA256{ lv_lf }{ lv_tstr }{ lv_lf }{ lv_scope }{ lv_lf }{ to_lower( |{ lv_bin }| ) }|.

    DATA(lv_key) = cl_abap_conv_out_ce=>create( encoding = 'UTF-8' )->convert( data = 'AWS4' && ls_aws_creds-secretaccesskey ).
    
    DATA(lv_sign_parts) = VALUE string_table( ( |{ lv_date DATE = RAW }| ) ( `us-gov-west-1` ) ( `sts` ) ( `aws4_request` ) ).
    LOOP AT lv_sign_parts INTO DATA(lv_part).
      cl_abap_hmac=>calculate_hmac_for_raw( EXPORTING if_algorithm = 'SHA256' if_key = lv_key if_data = cl_abap_conv_out_ce=>create( encoding = 'UTF-8' )->convert( data = lv_part ) IMPORTING ef_hmacxstring = lv_bin ).
      lv_key = lv_bin.
    ENDLOOP.

    cl_abap_hmac=>calculate_hmac_for_raw( EXPORTING if_algorithm = 'SHA256' if_key = lv_key if_data = cl_abap_conv_out_ce=>create( encoding = 'UTF-8' )->convert( data = lv_sts_str ) IMPORTING ef_hmacxstring = lv_bin ).
    DATA(lv_sig) = to_lower( |{ lv_bin }| ).

    DATA(lv_auth) = |AWS4-HMAC-SHA256 Credential={ ls_aws_creds-accesskeyid }/{ lv_scope }, SignedHeaders={ lv_signed_hdrs }, Signature={ lv_sig }|.

    DATA(lv_subj_json) = |\{"url":"https://sts.us-gov-west-1.amazonaws.com/?Action=GetCallerIdentity&Version=2011-06-15","method":"POST","headers":[| &&
                         |\{"key":"host","value":"sts.us-gov-west-1.amazonaws.com"\},| &&
                         |\{"key":"x-amz-date","value":"{ lv_tstr }"\},| &&
                         |\{"key":"x-amz-security-token","value":"{ ls_aws_creds-token }"\},| &&
                         |\{"key":"x-goog-cloud-target-resource","value":"{ iv_audience }"\},| &&
                         |\{"key":"Authorization","value":"{ lv_auth }"\}]\}|.
    
    DATA(lv_subject_token) = cl_http_utility=>escape_url( lv_subj_json ).

    " --- 3. GET GCP FEDERATED TOKEN ---
    cl_http_client=>create_by_url( EXPORTING url = 'https://sts.googleapis.com/v1/token' IMPORTING client = lo_http ).
    lo_http->request->set_method( 'POST' ).
    lo_http->request->set_header_field( name = 'Content-Type' value = 'application/json' ).
    lo_http->request->set_cdata( |\{"audience":"{ iv_audience }","grantType":"urn:ietf:params:oauth:grant-type:token-exchange",| &&
                                 |"requestedTokenType":"urn:ietf:params:oauth:token-type:access_token","scope":"https://www.googleapis.com/auth/cloud-platform",| &&
                                 |"subjectTokenType":"urn:ietf:params:aws:token-type:aws4_request","subjectToken":"{ lv_subject_token }"\}| ).
    lo_http->send( ). lo_http->receive( ).
    
    FIND REGEX '"access_token":\s*"([^"]+)"' IN lo_http->response->get_cdata( ) SUBMATCHES lv_fed_token.
    lo_http->close( ).

    " --- 4. IMPERSONATE SERVICE ACCOUNT (GET BQ TOKEN) ---
    IF lv_fed_token IS NOT INITIAL.
      cl_http_client=>create_by_url( EXPORTING url = |https://iamcredentials.googleapis.com/v1/projects/-/serviceAccounts/{ lv_sa_email }:generateAccessToken| IMPORTING client = lo_http ).
      lo_http->request->set_method( 'POST' ).
      lo_http->request->set_header_field( name = 'Authorization' value = |Bearer { lv_fed_token }| ).
      lo_http->request->set_cdata( '{"scope":["https://www.googleapis.com/auth/bigquery"]}' ).
      lo_http->send( ). lo_http->receive( ).
      
      " Return the final Access Token (BigQuery compatible) to the framework
      FIND REGEX '"accessToken":\s*"([^"]+)"' IN lo_http->response->get_cdata( ) SUBMATCHES rv_token.
      lo_http->close( ).
    ENDIF.

  ENDMETHOD.
